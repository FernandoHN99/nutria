# ============================================================================
# NutrIA Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================================

# ============================================================================
# BACKEND - Database Configuration (Local Development)
# ============================================================================
# For local development with Docker PostgreSQL
BACKEND_DB_HOST=localhost
BACKEND_DB_PORTA=5432
BACKEND_DB_USUARIO=nutria
BACKEND_DB_SENHA=nutria
BACKEND_DB_DATABASE=nutria

# ============================================================================
# BACKEND - Authentication
# ============================================================================
# JWT tokens - use at least 32 characters, preferably more
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
BACKEND_JWT_SECRET=seu-jwt-secret-min-32-chars-gerado-aleatoriamente
BACKEND_REFRESH_SECRET=seu-refresh-secret-min-32-chars-gerado-aleatoriamente

# ============================================================================
# BACKEND - OpenAI API (Optional - for Chatbot)
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys
BACKEND_OPEN_AI_API_KEY=sk-your-openai-key-here

# ============================================================================
# BACKEND - Node Environment
# ============================================================================
# development | production
BACKEND_NODE_ENV=development

# ============================================================================
# BACKEND - Production Database (Render/Neon)
# ============================================================================
# Only needed for production deployments
# Format: postgresql://user:password@host/database?sslmode=require
# BACKEND_DATABASE_URL=postgresql://user:password@host/database

# ============================================================================
# FRONTEND - Backend Connection
# ============================================================================
# URL where the backend is running
# For development: use your machine's IP or localhost
# For production: use the Render backend URL (e.g., https://backend-nutria.onrender.com)
BACKEND_URL=http://192.168.15.7
BACKEND_PORTA=5001

# ============================================================================
# Notes
# ============================================================================
# - Never commit .env files to git (see .gitignore)
# - .env.local is for local development
# - Production variables are managed via Render dashboard
# - Keep BACKEND_JWT_SECRET and BACKEND_REFRESH_SECRET secret and unique
