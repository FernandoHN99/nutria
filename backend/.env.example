# ============================================================================
# Backend Database Configuration (Local Development)
# ============================================================================
BACKEND_DB_HOST=localhost
BACKEND_DB_PORTA=5432
BACKEND_DB_USUARIO=nutria
BACKEND_DB_SENHA=nutria
BACKEND_DB_DATABASE=nutria

# ============================================================================
# Backend Authentication
# ============================================================================
# Gere valores fortes com:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
BACKEND_JWT_SECRET=seu-jwt-secret-min-32-chars-gerado-aleatoriamente
BACKEND_REFRESH_SECRET=seu-refresh-secret-min-32-chars-gerado-aleatoriamente

# ============================================================================
# Backend OpenAI API (Optional)
# ============================================================================
# BACKEND_OPEN_AI_API_KEY=sk-...

# ============================================================================
# Backend Node Environment
# ============================================================================
BACKEND_NODE_ENV=development

# ============================================================================
# Production Database (Optional)
# ============================================================================
# BACKEND_DATABASE_URL=postgresql://user:password@host/database
