# --- Production (Neon/Render) ---
# Use DATABASE_URL for managed services like Neon
# DATABASE_URL=postgresql://user:password@host/database

# --- Local Development ---
# Use individual DB variables for local Docker PostgreSQL
DB_USUARIO=postgres
DB_HOST=localhost
DB_DATABASE=nutria
DB_SENHA=nutria
DB_PORTA=5432

# --- Authentication ---
JWT_SECRET=your-secret-jwt-key-here-min-32-chars
REFRESH_SECRET=your-secret-refresh-key-here-min-32-chars

# --- OpenAI API ---
OPEN_AI_API_KEY=sk-your-openai-key-here

# --- Optional ---
# ANON_KEY=supabase-anon-key
# SERVICE_KEY=supabase-service-key
# API_EXTERNAL_URL=https://api.example.com
