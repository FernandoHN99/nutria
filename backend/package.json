{
   "name": "backend",
   "version": "0.0.1",
   "description": "NutrIA Backend API - Express + TypeORM",
   "private": true,
   "type": "commonjs",
   "devDependencies": {
      "@types/axios": "^0.14.0",
      "@types/bcryptjs": "^2.4.6",
      "@types/cookie-parser": "^1.4.7",
      "@types/cors": "^2.8.17",
      "@types/dotenv": "^8.2.0",
      "@types/express": "^4.17.21",
      "@types/jsonwebtoken": "^9.0.6",
      "@types/node": "^16.11.10",
      "@types/uuid-validate": "^0.0.3",
      "tsup": "8.4.0",
      "tsx": "^4.7.2",
      "typescript": "4.5.2"
   },
   "dependencies": {
      "bcryptjs": "^2.4.3",
      "cookie-parser": "^1.4.6",
      "cors": "^2.8.5",
      "directory-import": "^3.3.1",
      "dotenv": "^16.4.5",
      "express": "^4.19.2",
      "jsonwebtoken": "^9.0.2",
      "openai": "^4.65.0",
      "pg": "^8.4.0",
      "reflect-metadata": "^0.1.13",
      "typeorm": "0.3.20",
      "uuid-validate": "^0.0.3",
      "zod": "^3.22.5"
   },
   "scripts": {
      "start:dev": "NODE_NO_WARNINGS=1 tsx watch src/app.ts",
      "start": "node build/app.js",
      "typeorm": "tsx ./node_modules/typeorm/cli.js",
      "db:migrate": "tsx ./node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
      "db:migrate:revert": "tsx ./node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
      "db:seed": "tsx src/database/seed.ts",
      "build": "tsup src --out-dir build && mkdir -p build/data/seeds && cp data/seeds/*.csv build/data/seeds/"
   }
}